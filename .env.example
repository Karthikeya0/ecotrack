# ─────────────────────────────────────────────────────────────────────────────
#  EcoTrack Environment Variables
#  Copy this file to `.env` and fill in your credentials.
#  NEVER commit `.env` to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase ──────────────────────────────────────────────────────────────────
# Get these from: https://console.firebase.google.com
#   → Project Settings → General → Your apps → Web app → SDK setup

VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ── Groq API (AI Suggestions) ─────────────────────────────────────────────────
# Used by the Flask backend to call llama-3.3-70b-versatile
# Get your key at: https://console.groq.com/keys
VITE_GROQ_API_KEY=your-groq-api-key

# ── Carbon Interface API (Emission Calculations) ──────────────────────────────
# Used by the Flask backend for precise real-world emission factors
# Get your key at: https://www.carboninterface.com/
VITE_CARBON_INTERFACE_API_KEY=your-carbon-interface-api-key

# ── Flask Backend Base URL ────────────────────────────────────────────────────
# In development the Vite proxy forwards /api → Flask on port 5000
# In production replace this with your deployed backend URL
VITE_API_BASE_URL=http://localhost:5000
